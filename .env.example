# NetMe Environment Variables
# Copy this to .env.local and fill in your values

# Database
DATABASE_URL=postgres://netme:devpassword@localhost:5432/netme_dev

# Redis
REDIS_URL=redis://localhost:6379

# Backend API
API_PORT=8080
API_ENV=development

# Mobile
MOBILE_API_URL=http://localhost:8080/api/v1

# Auth (implement Clerk/Auth0/Firebase later)
# AUTH_PROVIDER=clerk  # or auth0, firebase
# AUTH_SECRET=xxx

# Plaid (implement after MVP auth)
# PLAID_CLIENT_ID=xxx
# PLAID_SECRET=xxx
# PLAID_ENV=sandbox  # or development, production

# Optional: Observability
# SENTRY_DSN=xxx
# LOG_LEVEL=debug  # debug, info, warn, error
