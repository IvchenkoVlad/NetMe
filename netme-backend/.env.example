DATABASE_URL=postgres://netme:devpassword@localhost:5432/netme_dev?sslmode=disable
API_PORT=8080
API_ENV=development

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-output-of-openssl-rand-hex-32

CORS_ALLOWED_ORIGINS=http://localhost:8081
MOBILE_API_URL=http://localhost:8080
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Plaid credentials (sandbox for dev, production for live)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# AES-256 key for encrypting Plaid access tokens at rest.
# Generate with: openssl rand -hex 32
# Leave empty in development to skip encryption (tokens stored plaintext).
# REQUIRED in production — server logs a warning if unset.
PLAID_TOKEN_ENCRYPTION_KEY=
